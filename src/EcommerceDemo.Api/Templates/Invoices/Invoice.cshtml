@model EcommerceDemo.Api.Services.Invoices.InvoiceViewModel
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Invoice @Model.OrderNumber</title>
    <style>
        :root {
            color: #172033;
            font-family: Arial, Helvetica, sans-serif;
            font-size: 12px;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: #ffffff;
            color: #172033;
        }

        .invoice {
            width: 100%;
        }

        header {
            display: flex;
            justify-content: space-between;
            gap: 32px;
            padding-bottom: 24px;
            border-bottom: 3px solid #0f766e;
        }

        h1, h2, p {
            margin: 0;
        }

        h1 {
            color: #0f766e;
            font-size: 28px;
            line-height: 1.1;
        }

        h2 {
            margin-bottom: 8px;
            color: #172033;
            font-size: 12px;
            text-transform: uppercase;
        }

        .muted {
            color: #64748b;
        }

        .invoice-meta {
            min-width: 220px;
            text-align: right;
        }

        .invoice-meta p + p,
        .contact p + p {
            margin-top: 5px;
        }

        .details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 32px;
            margin: 28px 0;
        }

        .panel {
            padding: 16px;
            border: 1px solid #cbd5e1;
            border-radius: 6px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            padding: 10px 8px;
            background: #e6fffb;
            color: #115e59;
            font-size: 10px;
            text-align: left;
            text-transform: uppercase;
        }

        td {
            padding: 11px 8px;
            border-bottom: 1px solid #e2e8f0;
            vertical-align: top;
        }

        .number {
            text-align: right;
            white-space: nowrap;
        }

        .summary {
            width: 280px;
            margin: 24px 0 0 auto;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            gap: 24px;
            padding: 6px 0;
        }

        .total {
            margin-top: 6px;
            padding-top: 12px;
            border-top: 2px solid #0f766e;
            color: #0f766e;
            font-size: 16px;
            font-weight: bold;
        }

        footer {
            margin-top: 36px;
            padding-top: 14px;
            border-top: 1px solid #cbd5e1;
            color: #64748b;
            font-size: 10px;
        }

        @@page {
            size: A4;
            margin: 12mm;
        }

        @@media print {
            .panel, tr {
                break-inside: avoid;
            }
        }
    </style>
</head>
<body>
<main class="invoice">
    <header>
        <div>
            <h1>@Model.StoreName</h1>
            <p class="muted">Invoice for order @Model.OrderNumber</p>
        </div>
        <div class="invoice-meta">
            <h2>Invoice</h2>
            <p><strong>Number:</strong> @Model.OrderNumber</p>
            <p><strong>Order date:</strong> @Model.OrderDate.ToString("MMMM d, yyyy")</p>
            <p><strong>Order status:</strong> @Model.OrderStatus</p>
        </div>
    </header>

    <section class="details">
        <div class="panel contact">
            <h2>Customer</h2>
            <p><strong>@Model.CustomerName</strong></p>
            @if (!string.IsNullOrWhiteSpace(Model.CompanyName))
            {
                <p>@Model.CompanyName</p>
            }
            <p>@Model.CustomerEmail</p>
            @if (!string.IsNullOrWhiteSpace(Model.CustomerPhone))
            {
                <p>@Model.CustomerPhone</p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.DeliveryAddress))
            {
                <p>@Model.DeliveryAddress</p>
            }
        </div>
        <div class="panel contact">
            <h2>Payment</h2>
            <p><strong>Method:</strong> @Model.PaymentMethod</p>
            <p><strong>Status:</strong> @Model.PaymentStatus</p>
        </div>
    </section>

    <table aria-label="Invoice line items">
        <thead>
        <tr>
            <th>Item</th>
            <th class="number">Quantity</th>
            <th class="number">Unit price</th>
            <th class="number">Line total</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.ProductName</td>
                <td class="number">@item.Quantity</td>
                <td class="number">@Model.FormatMoney(item.UnitPrice)</td>
                <td class="number">@Model.FormatMoney(item.LineTotal)</td>
            </tr>
        }
        </tbody>
    </table>

    <section class="summary" aria-label="Invoice totals">
        <div class="summary-row"><span>Subtotal</span><span>@Model.FormatMoney(Model.Subtotal)</span></div>
        <div class="summary-row"><span>Tax</span><span>@Model.FormatMoney(Model.Tax)</span></div>
        @if (Model.Discount > 0)
        {
            <div class="summary-row"><span>Discount</span><span>-@Model.FormatMoney(Model.Discount)</span></div>
        }
        <div class="summary-row total"><span>Total</span><span>@Model.FormatMoney(Model.Total)</span></div>
    </section>

    <footer>
        Generated server-side from persisted order data. Payment references and private provider data are not included.
    </footer>
</main>
</body>
</html>
